NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# Chief of Staff AI provider (Slice 5). Server-only — never exposed to the
# client, never referenced with NEXT_PUBLIC_. If unset, the Chief of Staff
# falls back to the deterministic-only briefing formatter automatically.
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5
AI_API_KEY=

# Chief of Staff unattended daily generation (Slice 5.1). Server-only.
# CRON_SECRET: shared secret Vercel Cron sends as `Authorization: Bearer <value>`
# when invoking /api/cron/chief-of-staff. Generate a long random value
# (e.g. `openssl rand -hex 32`) — never reuse SUPABASE_SERVICE_ROLE_KEY or
# any other existing secret for this.
CRON_SECRET=
# CHIEF_OF_STAFF_CRON_ORGANIZATION_ID: the single organisation the daily
# cron generates a briefing for. Must be a real organisation UUID. There
# is deliberately no "first organisation" fallback — multi-organisation
# scheduling is out of scope for this slice.
CHIEF_OF_STAFF_CRON_ORGANIZATION_ID=
# CHIEF_OF_STAFF_TIME_ZONE: IANA timezone used to compute the daily
# briefing's organisation-local calendar date. Must be a valid IANA
# identifier (validated at request time) — never a raw UTC offset.
CHIEF_OF_STAFF_TIME_ZONE=Africa/Johannesburg
